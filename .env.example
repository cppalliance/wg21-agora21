# Copy to `.env` or `.env.local` in this repo root (see `agora21.credentials.load_repo_dotenv`).
# Repo root discovery: set when the package is not run from a source checkout.
# AGORA21_REPO_ROOT=

# LLM / Claude (OpenRouter maps to Anthropic-compatible env in code when configured)
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=

# Optional model overrides (see `agora21.config`)
# AUTHOR_MODEL=
# REVIEWER_MODEL=
# AUTHOR_TIMEOUT_S=
# REVIEWER_TIMEOUT_S=
# MAX_REVIEW_ROUNDS=

# Claude Code permission mode (passed through to runner)
# WG21_CLAUDE_PERMISSION_MODE=acceptEdits

# Mailing hint when fetching paper lists for `run` (optional)
# WG21_MAILING_ID=
# WG21_MAILING_URL=

# Parallel workers (optional; `run --max-processes` overrides)
# WG21_PARALLEL_WORKERS=

# Recovery / sandbox (see README)
# WG21_DISABLE_DISK_THREAD_RECOVERY=
# WG21_DISABLE_GIT_SANDBOX=

# Reviewer
# CURSOR_API_KEY=
